# ─── Maya Chat – Environment Variables ────────────────────────────────────────

# OpenAI API Key (required for Maya to work)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── WhatsApp Notifications via CallMeBot (free) ──────────────────────────────
# When a visitor leaves details, Maya sends YOU a WhatsApp notification.
#
# Setup (one-time, 2 minutes):
#  1. Add the CallMeBot number to your contacts: +34 644 59 77 23
#  2. Send this WhatsApp message to that number: "I allow callmebot to send me messages"
#  3. You'll receive your personal API key in reply.
#  4. Fill in the values below.
#
# Your phone number including country code, NO + sign (e.g. 972501234567)
CALLMEBOT_PHONE=972501234567

# The API key you received from CallMeBot
CALLMEBOT_APIKEY=YOUR_CALLMEBOT_APIKEY
